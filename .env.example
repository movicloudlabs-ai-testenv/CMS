APP_NAME="College Management System"
DB_NAME="College_db"

# --- College Management System (CMS) Backend Variables ---
# Replace with your actual MongoDB Atlas connection string (e.g. mongodb+srv://username:password@cluster.mongodb.net/dbname)
MONGODB_URI=your_mongodb_atlas_connection_string_here
PORT=5000
# CORS_ORIGINS can be set to override defaults. Format: comma-separated list of URLs
CORS_ORIGINS=

# --- CMS Frontend Variables ---
VITE_API_BASE_URL=http://localhost:5000

# --- Demo Login Credentials (hints visible on login page) ---
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123

DEMO_STUDENT_USERNAME=student
DEMO_STUDENT_PASSWORD=student123

DEMO_FINANCE_USERNAME=finance
DEMO_FINANCE_PASSWORD=finance123

DEMO_FACULTY_USERNAME=faculty
DEMO_FACULTY_PASSWORD=faculty123
